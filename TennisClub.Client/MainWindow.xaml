<Window x:Class="TennisClub.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tennis Club Membership" Height="560" Width="860">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock x:Name="StatusText" Text="Connecting…" />
        </StatusBar>

        <TabControl x:Name="MainTabControl" Margin="8" SelectionChanged="TabControl_SelectionChanged">

            <!-- ── Tab 1: Members ── -->
            <TabItem Header="Members">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="Sign Up New Member" Grid.Row="0" Margin="0,0,0,8">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Name:"  Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBox x:Name="NameTextBox"  Grid.Column="1" Margin="4,0" VerticalAlignment="Center"/>
                            <Label Content="Email:" Grid.Column="2" VerticalAlignment="Center"/>
                            <TextBox x:Name="EmailTextBox" Grid.Column="3" Margin="4,0" VerticalAlignment="Center"/>
                            <Button Content="Sign Up" Grid.Column="4" Padding="12,4" Click="SignUp_Click"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="All Members" Grid.Row="1">
                        <DockPanel Margin="4">
                            <Button DockPanel.Dock="Top" Content="Refresh" HorizontalAlignment="Left"
                                    Margin="0,0,0,4" Padding="12,4" Click="RefreshMembers_Click"/>
                            <ListView x:Name="MembersListView">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Name"   DisplayMemberBinding="{Binding Name}"                              Width="200"/>
                                        <GridViewColumn Header="Email"  DisplayMemberBinding="{Binding Email}"                             Width="240"/>
                                        <GridViewColumn Header="Joined" DisplayMemberBinding="{Binding JoinedAt, StringFormat=d}" Width="120"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ── Tab 2: Availability ── -->
            <TabItem Header="Availability">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Label Content="Date:" VerticalAlignment="Center"/>
                        <DatePicker x:Name="AvailabilityDatePicker" Width="140" Margin="4,0"/>
                        <Button Content="Check Availability" Padding="12,4" Click="CheckAvailability_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="AvailabilityGrid" Grid.Row="1"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Court"     Binding="{Binding CourtNumber}"    Width="60"/>
                            <DataGridTextColumn Header="Time Slot" Binding="{Binding TimeSlotDisplay}" Width="130"/>
                            <DataGridTextColumn Header="Status"    Binding="{Binding StatusDisplay}"   Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ── Tab 3: Book a Court ── -->
            <TabItem Header="Book a Court">
                <GroupBox Header="New Booking" Margin="8">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="Date:"      Grid.Row="0" Grid.Column="0" Margin="4" VerticalAlignment="Center"/>
                        <DatePicker x:Name="BookDatePicker" Grid.Row="0" Grid.Column="1" Margin="4"/>

                        <Label Content="Court:"     Grid.Row="1" Grid.Column="0" Margin="4" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CourtComboBox" Grid.Row="1" Grid.Column="1" Margin="4">
                            <ComboBoxItem Tag="1">Court 1</ComboBoxItem>
                            <ComboBoxItem Tag="2">Court 2</ComboBoxItem>
                            <ComboBoxItem Tag="3">Court 3</ComboBoxItem>
                        </ComboBox>

                        <Label Content="Time Slot:" Grid.Row="2" Grid.Column="0" Margin="4" VerticalAlignment="Center"/>
                        <ComboBox x:Name="SlotComboBox" Grid.Row="2" Grid.Column="1" Margin="4">
                            <ComboBoxItem Tag="17">17:00 – 18:00</ComboBoxItem>
                            <ComboBoxItem Tag="18">18:00 – 19:00</ComboBoxItem>
                            <ComboBoxItem Tag="19">19:00 – 20:00</ComboBoxItem>
                        </ComboBox>

                        <Label Content="Member 1:" Grid.Row="3" Grid.Column="0" Margin="4" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Member1ComboBox" Grid.Row="3" Grid.Column="1" Margin="4" DisplayMemberPath="Name"/>

                        <Label Content="Member 2:" Grid.Row="4" Grid.Column="0" Margin="4" VerticalAlignment="Center"/>
                        <ComboBox x:Name="Member2ComboBox" Grid.Row="4" Grid.Column="1" Margin="4" DisplayMemberPath="Name"/>

                        <Button Content="Book Court" Grid.Row="5" Grid.Column="1" Margin="4,16,4,4"
                                HorizontalAlignment="Right" Padding="16,6" Click="Book_Click"/>
                    </Grid>
                </GroupBox>
            </TabItem>

            <!-- ── Tab 4: Bookings ── -->
            <TabItem Header="Bookings">
                <DockPanel Margin="8">
                    <Button DockPanel.Dock="Top" Content="Refresh" HorizontalAlignment="Left"
                            Margin="0,0,0,8" Padding="12,4" Click="RefreshBookings_Click"/>
                    <DataGrid x:Name="BookingsGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date"      Binding="{Binding Date, StringFormat=d}"  Width="100"/>
                            <DataGridTextColumn Header="Court"     Binding="{Binding CourtNumber}"            Width="60"/>
                            <DataGridTextColumn Header="Time Slot" Binding="{Binding TimeSlotDisplay}"        Width="130"/>
                            <DataGridTextColumn Header="Member 1"  Binding="{Binding Member1Name}"            Width="160"/>
                            <DataGridTextColumn Header="Member 2"  Binding="{Binding Member2Name}"            Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- ── Tab 5: Live Feed ── -->
            <TabItem Header="Live Feed">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock VerticalAlignment="Center" FontStyle="Italic" Foreground="Gray"
                                   Text="Server-push messages appear here automatically when any client makes a booking."/>
                        <Button Content="Clear" Margin="12,0,0,0" Padding="10,3" Click="ClearFeed_Click"/>
                    </StackPanel>
                    <ListBox x:Name="LiveFeedListBox"
                             FontFamily="Consolas" FontSize="12"
                             Background="#1E1E1E" Foreground="#D4D4D4"
                             BorderThickness="1" BorderBrush="#444"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
